    "test:watch": "vitest"
  },
  "dependencies": {
    "@pi-router/messages": "workspace:*",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@vitejs/plugin-vue": "^5.2.3",
    "typescript": "^5.9.2",
    "vite": "^6.3.5",
    "vitest": "^4.1.9",
    "vue-tsc": "^2.2.10"
  }
}
