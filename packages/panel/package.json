{
  "name": "@pi-router/panel",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "eslint",
