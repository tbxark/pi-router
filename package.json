{
  "name": "pi-router-monorepo",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/tbxark/pi-router"
  },
  "scripts": {
    "build": "pnpm --filter @pi-router/config-panel run build && pnpm --filter pi-router run build",
    "build:config-panel": "pnpm --filter @pi-router/config-panel run build",
    "build:extension": "pnpm --filter pi-router run build",
    "bundle": "pnpm --filter pi-router run bundle",
    "compile": "pnpm run -r compile",
    "format": "pnpm run -r format",
    "format:check": "pnpm run -r format:check",
    "lint": "pnpm run -r lint",
    "lint:fix": "pnpm run -r lint:fix",
    "test": "pnpm run -r test",
    "test:watch": "pnpm run -r test:watch",
    "package:vsix": "pnpm run build && pnpm --filter pi-router run package:vsix",
    "install:vsix": "pnpm run package:vsix && code --install-extension packages/extension/pi-router.vsix",
    "publish:vsix": "pnpm run package:vsix && pnpm dlx vsce publish --packagePath packages/extension/pi-router.vsix"
  },
  "author": "tbxark",
  "license": "MIT",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.7.0",
      "onFail": "download"
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@stylistic/eslint-plugin": "^2.9.0",
    "@types/node": "^22",
    "@types/vscode": "1.125.0",
    "eslint": "^9.13.0",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.39.0",
    "vitest": "^4.1.9"
  }
}
